{
  "name": "felix-natalis",
  "version": "0.1.0",
  "description": "Birthday reminder API written in Node/TypeScript",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=tests/unit --runInBand",
    "test:integration": "jest --testPathPatterns=tests/integration --runInBand --testTimeout=60000",
    "test:integration:user": "jest --testPathPatterns=tests/integration/user --runInBand --testTimeout=60000",
    "test:integration:reminder": "jest --testPathPatterns=tests/integration/reminder --runInBand --testTimeout=60000"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bullmq": "^5.75.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "luxon": "^3.7.2",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "redlock": "^5.0.0-beta.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@testcontainers/mongodb": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/joi": "^17.2.2",
    "@types/luxon": "^3.7.1",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/redis": "^4.0.10",
    "@types/redlock": "^4.0.8",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
